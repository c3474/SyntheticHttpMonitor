{
  "Alerting": {
    "FailureThreshold": 2,
    "RepeatWhileDownMinutes": 60,
    "SendRecoveryEmail": true
  },
  "Smtp": {
    "Enabled": true,

    "// AuthMode options": "Password | GmailOAuth2 | ExchangeOAuth2",

    "// --- Password (internal relay, no auth) ---": {},
    "Host": "smtp-relay.internal.example.com",
    "Port": 25,
    "UseSsl": false,
    "UseStartTls": true,
    "AuthMode": "Password",
    "Username": "",
    "Password": "",

    "// --- Gmail OAuth2 ---": {},
    "// Host": "smtp.gmail.com",
    "// Port": 465,
    "// UseSsl": true,
    "// UseStartTls": false,
    "// AuthMode": "GmailOAuth2",
    "// Username": "monitor@gmail.com",
    "// ClientId": "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com",
    "// ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET",
    "// RefreshToken": "YOUR_REFRESH_TOKEN",

    "// --- Exchange Online (Microsoft 365) OAuth2 ---": {},
    "// Host": "smtp.office365.com",
    "// Port": 587,
    "// UseSsl": false,
    "// UseStartTls": true,
    "// AuthMode": "ExchangeOAuth2",
    "// Username": "monitor@yourdomain.com",
    "// ClientId": "YOUR_AZURE_APP_CLIENT_ID",
    "// ClientSecret": "YOUR_AZURE_APP_CLIENT_SECRET",
    "// RefreshToken": "YOUR_REFRESH_TOKEN",
    "// TenantId": "YOUR_AZURE_TENANT_ID",

    "From": "synthetic-monitor@internal.example.com",
    "To": [ "ops-alerts@internal.example.com" ],
    "Cc": [],
    "SubjectDownPrefix": "[DOWN]",
    "SubjectRecoveryPrefix": "[RECOVERED]"
  },
  "PagerDuty": {
    "Enabled": false,
    "RoutingKey": "",
    "EventsApiUrl": "https://events.pagerduty.com/v2/enqueue",
    "Severity": "critical",
    "Source": "",
    "ResolveOnRecovery": true
  },
  "TicketingApi": {
    "Enabled": false,
    "BaseUrl": "https://ticketing.internal.example.com/api/",
    "ApiKeyHeaderName": "X-API-Key",
    "ApiKey": "",
    "ProjectKey": "NETOPS"
  }
