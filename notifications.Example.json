{
  "Alerting": {
    "FailureThreshold": 2,
    "RepeatWhileDownMinutes": 60,
    "SendRecoveryEmail": true
  },
  "Smtp": {
    "Enabled": true,
    "Host": "smtp-relay.internal.example.com",
    "Port": 25,
    "UseSsl": false,
    "UseStartTls": true,
    "Username": "",
    "Password": "",
