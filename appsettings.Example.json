{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.EventLog"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "C:\\ProgramData\\SyntheticHttpMonitor\\logs\\synthetic-http-monitor-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:O}] [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "EventLog",
        "Args": {
          "source": "SyntheticHttpMonitor",
          "logName": "Application",
          "manageEventSource": true
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "SyntheticMonitor": {
    "Defaults": {
      "IntervalSeconds": 60,
      "TimeoutSeconds": 10,
      "ExpectedStatusCodes": [ 200 ],
      "MaxBodyBytes": 262144,
      "DangerousAcceptAnyServerCertificate": false,
      "HttpMethod": "GET",
      "Headers": {
        "User-Agent": "SyntheticHttpMonitor/1.0"
      }
    },
    "Targets": [
      {
        "Name": "Orion Login",
        "Url": "https://orion.example.com/Orion/Login.aspx",
        "IntervalSeconds": 120,
        "TimeoutSeconds": 15,
        "ExpectedStatusCodes": [ 200 ],
        "BodyRegex": "SolarWinds",
        "MaxBodyBytes": 262144,
        "DangerousAcceptAnyServerCertificate": false
      },
      {
        "Name": "Status page (regex only)",
        "Url": "https://status.example.com/",
        "ExpectedStatusCodes": [ 200, 204 ],
        "BodyRegex": null
      }
    ]
  },
  "Alerting": {
    "FailureThreshold": 2,
    "RepeatWhileDownMinutes": 60,
    "SendRecoveryEmail": true
  },
  "Smtp": {
    "Enabled": true,
    "Host": "smtp-relay.internal.example.com",
    "Port": 25,
    "UseSsl": false,
    "UseStartTls": true,
    "Username": "",
    "Password": "",
    "From": "synthetic-monitor@internal.example.com",
    "To": [ "ops-alerts@internal.example.com" ],
    "Cc": [],
    "SubjectDownPrefix": "[DOWN]",
    "SubjectRecoveryPrefix": "[RECOVERED]"
  },
  "PagerDuty": {
    "Enabled": false,
    "RoutingKey": "",
    "EventsApiUrl": "https://events.pagerduty.com/v2/enqueue",
    "Severity": "critical",
    "Source": "",
    "ResolveOnRecovery": true
  },
  "TicketingApi": {
    "Enabled": false,
    "BaseUrl": "https://ticketing.internal.example.com/api/",
    "ApiKeyHeaderName": "X-API-Key",
    "ApiKey": "",
    "ProjectKey": "NETOPS"
  }
}
